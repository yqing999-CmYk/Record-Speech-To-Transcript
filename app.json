{
  "expo": {
    "name": "RecordSpeechToTranscript",
    "slug": "record-speech-to-transcript",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow RecordSpeechToTranscript to access your microphone."
        }
      ]
    ]
  }
}
